
import java.util.*;
public class hollow1{
public static void main(String[]args){
    Scanner sc= new Scanner(System.in);
    int m=sc.nextInt();
    int n=sc.nextInt();
    int s=m/2;
    int s1=n/2;
    for (int i=0;i<m;i++){
        for(int j=0;j<n;j++){
            if(i==0 || j==0 || i==n-1 || j==m-1 || i==s || j==s1){
                System.out.print("* ");}
            else{
                System.out.print("  ");
    }
}
            System.out.println();
        }
}
}
